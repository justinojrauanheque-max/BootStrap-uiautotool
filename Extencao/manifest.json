{
  "manifest_version": 3,
  "name": "Auto Clicker - Form Helper",
  "version": "2.0.1",
  "description": "Automates clicks and form filling on dynamic websites to optimize your web tasks",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "webNavigation",
    "contextMenus",
    "userScripts"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "images/logo-16.png",
      "32": "images/logo-32.png",
      "48": "images/logo-48.png",
      "128": "images/logo-128.png"
    }
  },
  "icons": {
    "16": "images/logo-16.png",
    "32": "images/logo-32.png",
    "48": "images/logo-48.png",
    "128": "images/logo-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "start-ocr-capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Capture an OCR automation target"
    }
  },
  "options_ui": {
    "page": "options_redirect.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["scripts/userScriptMainWorld.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["scripts/userScriptBootstrap.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["scripts/selectorCapture.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["scripts/ocrRunner.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://uiautotool.vercel.app/options.html*",
        "https://bfjhgisfzdsefjjojbov.supabase.co/storage/v1/object/public/web/options.html*",
        "http://127.0.0.1:5500/options.html*",
        "http://localhost:5500/options.html*",
        "http://127.0.0.1:5500/web/options.html*",
        "http://localhost:5500/web/options.html*",
        "http://127.0.0.1:5500/*",
        "http://localhost:5500/*"
      ],
      "js": ["scripts/webStorageBridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/codemirror/codemirror.js",
        "lib/codemirror/codemirror.css",
        "lib/codemirror/mode/javascript/javascript.js",
        "lib/codemirror/theme/monokai.css",
        "lib/codemirror/addon/edit/matchbrackets.js",
        "lib/codemirror/addon/edit/closebrackets.js",
        "images/logo.png",
        "images/logo-16.png",
        "images/logo-32.png",
        "images/logo-48.png",
        "images/logo-128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
